{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "uma",
      "camelcase": "UmaLang",
      "scope": "source.uma",
      "file-types": ["uma"],
      "injection-regex": "^uma$",
      "class-name": "TreeSitterUma",
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Uma grammar for tree-sitter",
    "authors": [
      {
        "name": "Grazen"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-uma"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
